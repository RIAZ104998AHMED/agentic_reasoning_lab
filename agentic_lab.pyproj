    <Compile Include="observability\replay.py" />
    <Compile Include="strategies\base.py" />
    <Compile Include="strategies\plan_execute.py" />
    <Compile Include="strategies\react.py" />
    <Compile Include="strategies\self_consistency.py" />
    <Compile Include="strategies\tree_of_thoughts.py" />
    <Compile Include="tools\registry.py" />
    <Compile Include="__init__.py" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="eval\" />
    <Folder Include="observability\" />
    <Folder Include="tools\" />
    <Folder Include="strategies\" />
  </ItemGroup>
  <ItemGroup>
    <Content Include=".env" />
    <Content Include="eval\golden_set.json" />
    <Content Include="requirements.txt" />
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
